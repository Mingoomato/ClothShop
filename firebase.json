{
  "firestore": {
    "rules": "firestore.rules"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
      "public": ".",
      "ignore": [
          "firebase.json",
          "**/*.rules",
          "**/.*",
          "**/node_modules/**"
      ],
      "headers": [
          {
              "source": "**",
              "headers": [
                  {
                      "key": "Content-Security-Policy",
                      "value": "default-src 'self' https: data: blob: 'unsafe-inline' 'unsafe-eval';"
                  }
              ]
          }
      ]
  }
}
